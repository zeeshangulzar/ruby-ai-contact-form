# ─── Mailtrap Email Sending ───────────────────────────────────────────────────
# API token from: Mailtrap → Settings → API Tokens (needs the "Admin" scope on
# your sending domain). The same token is used as the SMTP password.
MAILTRAP_API_TOKEN=your_mailtrap_api_token

# Verified sender address. During development you can use the free demo domain:
#   hello@demomailtrap.co  (emails will only reach your Mailtrap account email)
# For production, use an address on your own verified sending domain.
MAILTRAP_FROM_EMAIL=hello@demomailtrap.co

# ─── Anthropic API ────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Team routing emails ───────────────────────────────────────────────────────
# When using the demomailtrap.co demo domain, all four must be your Mailtrap
# account owner email — the demo domain can only deliver to that address.
TEAM_EMAIL_SALES=sales@yourdomain.com
TEAM_EMAIL_SUPPORT=support@yourdomain.com
TEAM_EMAIL_PARTNERSHIP=partnerships@yourdomain.com
TEAM_EMAIL_OTHER=hello@yourdomain.com
