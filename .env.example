# ─── Mailtrap Sandbox SMTP (development) ──────────────────────────────────────
# Get from: Sandboxes → My Sandbox → Integrations → Ruby on Rails
MAILTRAP_SMTP_USER=your_smtp_username
MAILTRAP_SMTP_PASS=your_smtp_password

# ─── Mailtrap Sending API (production) ────────────────────────────────────────
# Get from: Settings → API Tokens (requires a verified sending domain)
MAILTRAP_API_KEY=your_sending_api_key

# Sender address used in all outgoing emails
MAILTRAP_FROM_EMAIL=no-reply@yourdomain.com

# ─── Anthropic API ────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Team routing emails ───────────────────────────────────────────────────────
TEAM_EMAIL_SALES=sales@yourdomain.com
TEAM_EMAIL_SUPPORT=support@yourdomain.com
TEAM_EMAIL_PARTNERSHIP=partnerships@yourdomain.com
TEAM_EMAIL_OTHER=hello@yourdomain.com
